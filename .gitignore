# ==========================================
# 基于截图明确需要忽略的文件和文件夹
# ==========================================

# 忽略 Visual Studio 隐藏缓存目录
.vs/

# 忽略编译输出目录 (通常包含 .exe, .pdb 等)
x64/

# 忽略用户特定的项目配置文件
*.user

# ==========================================
# 强烈建议添加的标准 Visual Studio C++ 忽略规则
# (防止未来编译产生其他垃圾文件被误传)
# ==========================================

# 其他常见的构建输出目录
Debug/
Release/
x86/
build/
bin/
obj/

# 产生的临时文件和中间文件
*.obj
*.ilk
*.tlb
*.tli
*.tlh
*.tmp
*.rsp
*.pgc
*.pgd
*.meta

# 数据库、缓存和调试文件
*.pdb
*.idb
*.sdf
*.suo
*.dbmdl
*.ipch
*.aps
*.ncb
*.opendb
*.VC.db

# 忽略系统生成的缩略图缓存
Thumbs.db